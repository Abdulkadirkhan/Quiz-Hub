{
  "name": "quiz-buzzer-hub",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "pnpm --filter @workspace/quiz-buzzer build && pnpm --filter @workspace/api-server build",
    "build:frontend": "pnpm --filter @workspace/quiz-buzzer build",
    "build:backend": "pnpm --filter @workspace/api-server build",
    "start": "pnpm --filter @workspace/api-server start",
    "dev:frontend": "pnpm --filter @workspace/quiz-buzzer dev",
    "dev:backend": "pnpm --filter @workspace/api-server dev",
    "typecheck": "pnpm -r --if-present run typecheck"
  },
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
